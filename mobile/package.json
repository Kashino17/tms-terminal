    "@react-native-firebase/messaging": "^20.5.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "~50.0.0",
    "expo-asset": "~9.0.2",
    "expo-av": "~13.10.6",
    "expo-background-fetch": "~11.8.1",
    "expo-clipboard": "~5.0.1",
    "expo-crypto": "~12.8.1",
